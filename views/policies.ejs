<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Управление полисами — СтрахГарант</title>
    <link rel="stylesheet" href="/stylesheets/policies.css">
    <link rel="stylesheet" href="/stylesheets/style.css"> 
</head>

<body>

    <header class="header">
        <h2 class="header__title">СтрахГарант</h2>
        <div class="header__info">Страховая организация</div>
    </header>

    <nav class="nav">
        <button onclick="location.href='/'">Главная</button>
        <button onclick="location.href='/#Products'">Страховые продукты</button>
        <button onclick="location.href='/#About'">О нас</button>
        <button class="active">Управление полисами</button>
    </nav>

    <div id="IForm">
        <h2 style="color:#1a6fad; margin-bottom:1rem">Управление полисами</h2>

        <div class="about-block" style="width:100%; max-width:500px; margin-bottom:2rem">
            <h4>Добавить полис</h4>
            <input id="newName" placeholder="Название"
                style="width:100%; padding:0.5rem; margin-bottom:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
            <input id="newDesc" placeholder="Описание"
                style="width:100%; padding:0.5rem; margin-bottom:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
            <button class="btn" onclick="addItem()">Добавить</button>
        </div>

        <div class="container__table" style="width:100%; max-width:500px; margin-bottom:1rem">
            <h4>Поиск полиса</h4>
            <div style="display:flex; gap:0.5rem; align-items:center">
                <input id="searchName" placeholder="Название полиса"
                    style="flex:1; padding:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
                <button class="btn" type="button" onclick="searchPolicy()">Найти</button>
                <button class="btn" type="button" onclick="sortPoliciesByName()">Сортировать по имени</button>
            </div>
        </div>

        <table class="products-table" style="width:100%">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Описание</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% items.forEach(function(item, index) { %>
                    <tr id="row-<%= index %>">
                        <td>
                            <%= item.name %>
                        </td>
                        <td>
                            <%= item.description %>
                        </td>
                        <td style="display:flex; gap:0.5rem">
                            <button class="btn" onclick="editItem(<%= index %>, '<%= item.name %>', '<%= item.description %>')">Изменить</button>
                            <button class="btn" style="background:#e05555"
                                onclick="deleteItem(<%= index %>)">Удалить</button>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>
        <div style="display:flex; justify-content:center; align-items:center; gap:0.5rem; margin-top:1rem">
            <button class="btn" type="button" onclick="changePage(-1)">Назад</button>
            <span id="paginationInfo" style="color:#1a6fad; font-weight:600">Страница 1</span>
            <button class="btn" type="button" onclick="changePage(1)">Вперед</button>
        </div>

        <div id="editForm" class="about-block" style="display:none; width:100%; max-width:500px; margin-top:2rem">
            <h3>Редактировать полис</h3>
            <input id="editId" type="hidden">
            <input id="editName" placeholder="Название"
                style="width:100%; padding:0.5rem; margin-bottom:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
            <input id="editDesc" placeholder="Описание"
                style="width:100%; padding:0.5rem; margin-bottom:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
            <div style="display:flex; gap:0.5rem">
                <button class="btn" onclick="saveEdit()">Сохранить</button>
                <button class="btn" style="background:#aaa" onclick="cancelEdit()">Отмена</button>
            </div>
        </div>
    </div>

    <script>
        let highlightTimeoutId;
        let sortAsc = true;
        let currentPage = 1;
        const rowsPerPage = 5;

        function deleteItem(id) {
            fetch('/items/' + id, { method: 'DELETE' })
                .then(() => location.reload());
        }

        function editItem(id, name, desc) {
            document.getElementById('editForm').style.display = 'block';
            document.getElementById('editId').value = id; 
            document.getElementById('editName').value = name;
            document.getElementById('editDesc').value = desc;
        }

        function saveEdit() {
            const id = document.getElementById('editId').value;
            const name = document.getElementById('editName').value;
            const desc = document.getElementById('editDesc').value;

            fetch('/items/' + id, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: name, description: desc })
            }).then(() => location.reload());
        }

        function cancelEdit() {
            document.getElementById('editForm').style.display = 'none';
        }

        function addItem() {
            const name = document.getElementById('newName').value.trim();
            const desc = document.getElementById('newDesc').value.trim();

            if(!name || !desc) {
                alert('Заполните все поля!');
                return;
            }

            fetch('/items', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: name, description: desc })
            }).then(() => location.reload());
        }

        function searchPolicy() {
            const searchName = document.getElementById('searchName').value.trim().toLowerCase();
            const rows = document.querySelectorAll('.products-table tbody tr');
            let hasMatches = false;

            clearTimeout(highlightTimeoutId);
            clearSearchHighlight();

            if (!searchName) {
                return;
            }

            rows.forEach((row) => {
                const nameCell = row.querySelector('td');
                const policyName = nameCell ? nameCell.textContent.trim().toLowerCase() : '';

                if (policyName.includes(searchName)) {
                    row.style.backgroundColor = '#fff2a8';
                    hasMatches = true;
                }
            });

            if (!hasMatches) {
                alert('Полис с таким названием не найден.');
                return;
            }

            highlightTimeoutId = setTimeout(clearSearchHighlight, 2500);
        }

        function clearSearchHighlight() {
            const rows = document.querySelectorAll('.products-table tbody tr');
            rows.forEach((row) => {
                row.style.backgroundColor = '';
            });
        }

        function sortPoliciesByName() {
            const tbody = document.querySelector('.products-table tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.sort((a, b) => {
                const nameA = a.querySelector('td').textContent.trim().toLowerCase();
                const nameB = b.querySelector('td').textContent.trim().toLowerCase();
                return sortAsc ? nameA.localeCompare(nameB) : nameB.localeCompare(nameA);
            });

            rows.forEach((row) => tbody.appendChild(row));
            sortAsc = !sortAsc;
            showPage(1);
        }

        function getPolicyRows() {
            return Array.from(document.querySelectorAll('.products-table tbody tr'));
        }

        function getTotalPages() {
            const totalRows = getPolicyRows().length;
            return Math.max(1, Math.ceil(totalRows / rowsPerPage));
        }

        function showPage(page) {
            const rows = getPolicyRows();
            const totalPages = getTotalPages();
            currentPage = Math.min(Math.max(page, 1), totalPages);

            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;

            rows.forEach((row, index) => {
                row.style.display = index >= start && index < end ? '' : 'none';
            });

            document.getElementById('paginationInfo').textContent = `Страница ${currentPage} из ${totalPages}`;
        }

        function changePage(delta) {
            showPage(currentPage + delta);
        }

        showPage(1);
        
    </script>

</body>

</html>