<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Управление полисами — СтрахГарант</title>
    <link rel="stylesheet" href="/stylesheets/policies.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        .sort-header {
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
        }
        .sort-header:hover { background: #d0eaff; }
        .sort-arrow {
            display: inline-block;
            margin-left: 6px;
            font-size: 0.8em;
            color: #1a6fad;
        }
    </style>
</head>

<body>

    <header class="header">
        <h2 class="header__title">СтрахГарант</h2>
        <div class="header__info">Страховая организация</div>
    </header>

    <nav class="nav">
        <button onclick="location.href='/'">Главная</button>
        <button onclick="location.href='/#Products'">Страховые продукты</button>
        <button onclick="location.href='/#About'">О нас</button>
        <button class="active">Управление полисами</button>
    </nav>

    <div id="IForm">
        <h2 style="color:#1a6fad; margin-bottom:1rem">Управление полисами</h2>

        <div class="about-block" style="width:100%; max-width:500px; margin-bottom:2rem">
            <h4>Добавить полис</h4>
            <input id="newName" placeholder="Название"
                style="width:100%; padding:0.5rem; margin-bottom:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
            <input id="newDesc" placeholder="Описание"
                style="width:100%; padding:0.5rem; margin-bottom:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
            <button class="btn" onclick="addItem()">Добавить</button>
        </div>

        <div class="container__table" style="width:100%; max-width:500px; margin-bottom:1rem">
            <h4>Поиск полиса</h4>
            <div style="display:flex; gap:0.5rem; align-items:center">
                <input id="searchName" placeholder="Название полиса" value="<%= search %>"
                    style="flex:1; padding:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
                <button class="btn" type="button" onclick="searchPolicy()">Найти</button>
                <button class="btn" type="button" onclick="clearSearch()" style="background:#e05555;">Сбросить</button>
            </div>
        </div>

        <table class="products-table" style="width:100%">
            <thead>
                <tr>
                    <th class="sort-header" onclick="toggleSort()" title="Сортировать по названию">
                        Название
                        <span class="sort-arrow"><%= sortOrder === 'asc' ? '▲' : '▼' %></span>
                    </th>
                    <th>Описание</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% items.forEach(function(item, index) { %>
                    <tr>
                        <td><%= item.name %></td>
                        <td><%= item.description %></td>
                        <td style="display:flex; gap:0.5rem">
                            <button class="btn"
                                onclick="editItem(<%= item.id ?? index %>, '<%= item.name %>', '<%= item.description %>')">
                                Изменить
                            </button>
                            <button class="btn" style="background:#e05555"
                                onclick="deleteItem(<%= item.id ?? index %>)">
                                Удалить
                            </button>
                        </td>
                    </tr>
                <% }) %>
                <% if (items.length === 0) { %>
                    <tr>
                        <td colspan="3" style="text-align:center; color:#999; padding:1rem;">
                            Полисы не найдены
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <div style="display:flex; justify-content:center; align-items:center; gap:0.5rem; margin-top:1rem">
            <% if (currentPage > 1) { %>
                <button class="btn" type="button" onclick="goToPage(<%= currentPage - 1 %>)">Назад</button>
            <% } else { %>
                <button class="btn" type="button" disabled style="opacity:0.4; cursor:default;">Назад</button>
            <% } %>

            <span style="color:#1a6fad; font-weight:600">
                Страница <%= currentPage %> из <%= totalPages %>
            </span>

            <% if (currentPage < totalPages) { %>
                <button class="btn" type="button" onclick="goToPage(<%= currentPage + 1 %>)">Вперед</button>
            <% } else { %>
                <button class="btn" type="button" disabled style="opacity:0.4; cursor:default;">Вперед</button>
            <% } %>
        </div>

        <div id="editForm" class="about-block" style="display:none; width:100%; max-width:500px; margin-top:2rem">
            <h3>Редактировать полис</h3>
            <input id="editId" type="hidden">
            <input id="editName" placeholder="Название"
                style="width:100%; padding:0.5rem; margin-bottom:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
            <input id="editDesc" placeholder="Описание"
                style="width:100%; padding:0.5rem; margin-bottom:0.5rem; border:1px solid #b8ddf7; border-radius:8px">
            <div style="display:flex; gap:0.5rem">
                <button class="btn" onclick="saveEdit()">Сохранить</button>
                <button class="btn" style="background:#aaa" onclick="cancelEdit()">Отмена</button>
            </div>
        </div>
    </div>

    <script>
  
        let currentPage  = <%= currentPage %>;
        let currentSort  = '<%= sortOrder %>';    // 'asc' | 'desc'
        let currentSearch = '<%= search %>';

        // Сборка URL с актуальными параметрами
        function buildUrl({ page, sort, search }) {
            const p      = page   !== undefined ? page   : currentPage;
            const s      = sort   !== undefined ? sort   : currentSort;
            const q      = search !== undefined ? search : currentSearch;
            const params = new URLSearchParams({ page: p, sort: s });
            if (q) params.set('search', q);
            return '/policies?' + params.toString();
        }

        function goToPage(page) {
            location.href = buildUrl({ page });
        }

        function toggleSort() {
            const newSort = currentSort === 'asc' ? 'desc' : 'asc';
            location.href = buildUrl({ sort: newSort, page: 1 });
        }

        function searchPolicy() {
            const val = document.getElementById('searchName').value.trim();
            location.href = buildUrl({ search: val, page: 1 });
        }

        function clearSearch() {
            location.href = buildUrl({ search: '', page: 1 });
        }

        function deleteItem(id) {
            fetch('/items/' + id, { method: 'DELETE' })
                .then(() => location.reload());
        }

        function editItem(id, name, desc) {
            document.getElementById('editForm').style.display = 'block';
            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editDesc').value = desc;
        }

        function saveEdit() {
            const id   = document.getElementById('editId').value;
            const name = document.getElementById('editName').value;
            const desc = document.getElementById('editDesc').value;
            fetch('/items/' + id, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, description: desc })
            }).then(() => location.reload());
        }

        function cancelEdit() {
            document.getElementById('editForm').style.display = 'none';
        }

        function addItem() {
            const name = document.getElementById('newName').value.trim();
            const desc = document.getElementById('newDesc').value.trim();
            if (!name || !desc) { alert('Заполните все поля!'); return; }
            fetch('/items', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, description: desc })
            }).then(() => location.reload());
        }
    </script>

</body>
</html>
